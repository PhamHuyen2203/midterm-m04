<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootCheckout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mc_background"
    android:orientation="vertical"
    tools:context=".CheckoutActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarCheckout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/mc_toolbar_height"
        android:background="@color/mc_surface"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="@string/checkout_title"
        app:titleTextColor="@color/mc_text_primary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/progressBarCheckout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/mc_primary" />

        <ScrollView
            android:id="@+id/scrollViewCheckoutContent"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/mc_screen_padding"
                android:paddingTop="@dimen/mc_spacing_lg"
                android:paddingEnd="@dimen/mc_screen_padding"
                android:paddingBottom="@dimen/mc_spacing_xl">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/checkout_subtitle"
                    android:textColor="@color/mc_text_secondary"
                    android:textSize="@dimen/mc_text_body" />

                <!-- Trạng thái xác thực -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_lg"
                    app:cardBackgroundColor="@color/mc_success_soft"
                    app:cardCornerRadius="@dimen/mc_corner_radius"
                    app:cardElevation="@dimen/mc_card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/checkout_verified_title"
                            android:textColor="@color/mc_success"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:text="@string/checkout_verified_description"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_body" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Người mua -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_md"
                    app:cardBackgroundColor="@color/mc_surface"
                    app:cardCornerRadius="@dimen/mc_corner_radius"
                    app:cardElevation="@dimen/mc_card_elevation"
                    app:strokeColor="@color/mc_border"
                    app:strokeWidth="@dimen/mc_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/checkout_customer_heading"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewCheckoutCustomerName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:textColor="@color/mc_text_primary"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Tóm tắt giỏ hàng -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_md"
                    app:cardBackgroundColor="@color/mc_surface"
                    app:cardCornerRadius="@dimen/mc_corner_radius"
                    app:cardElevation="@dimen/mc_card_elevation"
                    app:strokeColor="@color/mc_border"
                    app:strokeWidth="@dimen/mc_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/checkout_summary_heading"
                            android:textColor="@color/mc_text_primary"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewCheckoutProductLines"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_md"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_body" />

                        <TextView
                            android:id="@+id/textViewCheckoutTotalQuantity"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_body" />

                        <TextView
                            android:id="@+id/textViewCheckoutTotalAmount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_md"
                            android:textColor="@color/mc_error"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewCheckoutEmpty"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_md"
                            android:text="@string/checkout_empty_cart"
                            android:textColor="@color/mc_warning"
                            android:textSize="@dimen/mc_text_body"
                            android:visibility="gone" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonContinueShopping"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_lg"
                    android:minHeight="@dimen/mc_button_height"
                    android:text="@string/button_continue_shopping"
                    android:textColor="@color/mc_primary"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/mc_corner_radius"
                    app:strokeColor="@color/mc_primary"
                    app:strokeWidth="@dimen/mc_stroke_width" />

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

</LinearLayout>