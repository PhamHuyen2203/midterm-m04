<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mc_background"
    android:fillViewport="true"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:paddingStart="@dimen/mc_screen_padding"
        android:paddingTop="@dimen/mc_spacing_xl"
        android:paddingEnd="@dimen/mc_screen_padding"
        android:paddingBottom="@dimen/mc_spacing_xl">

        <!-- Logo -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/mc_logo_size"
            android:layout_height="@dimen/mc_logo_size"
            app:cardBackgroundColor="@color/mc_primary"
            app:cardCornerRadius="@dimen/mc_card_radius_large"
            app:cardElevation="@dimen/mc_card_elevation">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="@string/brand_mark"
                android:textColor="@color/mc_text_on_primary"
                android:textSize="@dimen/mc_text_brand_mark"
                android:textStyle="bold" />

        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_lg"
            android:gravity="center"
            android:text="@string/login_title"
            android:textColor="@color/mc_text_primary"
            android:textSize="@dimen/mc_text_title"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_sm"
            android:gravity="center"
            android:lineSpacingExtra="@dimen/mc_spacing_xs"
            android:text="@string/login_description"
            android:textColor="@color/mc_text_secondary"
            android:textSize="@dimen/mc_text_body" />

        <!-- Form đăng nhập -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_xl"
            app:cardBackgroundColor="@color/mc_surface"
            app:cardCornerRadius="@dimen/mc_card_radius_large"
            app:cardElevation="@dimen/mc_card_elevation"
            app:strokeColor="@color/mc_border"
            app:strokeWidth="@dimen/mc_stroke_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/mc_card_padding">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_username"
                    app:boxBackgroundColor="@color/mc_surface"
                    app:boxStrokeColor="@color/mc_primary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextUsername"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="username"
                        android:imeOptions="actionNext"
                        android:inputType="text"
                        android:maxLines="1"
                        android:minHeight="@dimen/mc_input_min_height"
                        android:singleLine="true"
                        android:textColor="@color/mc_text_primary"
                        android:textSize="@dimen/mc_text_body" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_md"
                    android:hint="@string/hint_password"
                    app:boxBackgroundColor="@color/mc_surface"
                    app:boxStrokeColor="@color/mc_primary"
                    app:endIconMode="password_toggle">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/editTextPassword"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:autofillHints="password"
                        android:imeOptions="actionDone"
                        android:inputType="textPassword"
                        android:maxLines="1"
                        android:minHeight="@dimen/mc_input_min_height"
                        android:singleLine="true"
                        android:textColor="@color/mc_text_primary"
                        android:textSize="@dimen/mc_text_body" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/buttonLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_lg"
                    android:minHeight="@dimen/mc_button_height"
                    android:text="@string/button_login"
                    android:textColor="@color/mc_text_on_primary"
                    android:textSize="@dimen/mc_text_body"
                    android:textStyle="bold"
                    app:backgroundTint="@color/mc_primary"
                    app:cornerRadius="@dimen/mc_corner_radius" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Thông báo bảo mật -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_lg"
            app:cardBackgroundColor="@color/mc_primary_soft"
            app:cardCornerRadius="@dimen/mc_corner_radius"
            app:cardElevation="@dimen/mc_card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/mc_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/security_notice_title"
                    android:textColor="@color/mc_primary_dark"
                    android:textSize="@dimen/mc_text_body"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_xs"
                    android:lineSpacingExtra="@dimen/mc_spacing_xs"
                    android:text="@string/security_notice_description"
                    android:textColor="@color/mc_text_secondary"
                    android:textSize="@dimen/mc_text_caption" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

    </LinearLayout>

</ScrollView>