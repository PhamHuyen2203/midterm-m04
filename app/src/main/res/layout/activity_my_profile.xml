<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootMyProfile"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mc_background"
    android:orientation="vertical"
    tools:context=".MyProfileActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarMyProfile"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/mc_toolbar_height"
        android:background="@color/mc_surface"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="@string/my_profile_title"
        app:titleTextColor="@color/mc_text_primary" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ProgressBar
            android:id="@+id/progressBarMyProfile"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminateTint="@color/mc_primary" />

        <ScrollView
            android:id="@+id/scrollViewMyProfile"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fillViewport="true"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/mc_screen_padding"
                android:paddingTop="@dimen/mc_spacing_lg"
                android:paddingEnd="@dimen/mc_screen_padding"
                android:paddingBottom="@dimen/mc_spacing_xl">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/my_profile_subtitle"
                    android:textColor="@color/mc_text_secondary"
                    android:textSize="@dimen/mc_text_body" />

                <!-- Thông tin khách hàng -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_lg"
                    app:cardBackgroundColor="@color/mc_primary"
                    app:cardCornerRadius="@dimen/mc_card_radius_large"
                    app:cardElevation="@dimen/mc_card_elevation">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/profile_customer_label"
                            android:textColor="@color/mc_text_on_primary_muted"
                            android:textSize="@dimen/mc_text_caption"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/textViewProfileName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:textColor="@color/mc_text_on_primary"
                            android:textSize="@dimen/mc_text_title"
                            android:textStyle="bold" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_lg"
                    android:text="@string/profile_statistics_heading"
                    android:textColor="@color/mc_text_primary"
                    android:textSize="@dimen/mc_text_heading"
                    android:textStyle="bold" />

                <!-- Tổng số đơn -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_md"
                    app:cardBackgroundColor="@color/mc_surface"
                    app:cardCornerRadius="@dimen/mc_corner_radius"
                    app:cardElevation="@dimen/mc_card_elevation"
                    app:strokeColor="@color/mc_border"
                    app:strokeWidth="@dimen/mc_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:id="@+id/textViewTotalOrdersValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mc_primary"
                            android:textSize="@dimen/mc_profile_metric_value"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:text="@string/profile_total_orders_label"
                            android:textColor="@color/mc_text_primary"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_xs"
                            android:text="@string/profile_total_orders_description"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_caption" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Đơn giao thành công -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_profile_card_spacing"
                    app:cardBackgroundColor="@color/mc_surface"
                    app:cardCornerRadius="@dimen/mc_corner_radius"
                    app:cardElevation="@dimen/mc_card_elevation"
                    app:strokeColor="@color/mc_border"
                    app:strokeWidth="@dimen/mc_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:id="@+id/textViewDeliveredOrdersValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mc_success"
                            android:textSize="@dimen/mc_profile_metric_value"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:text="@string/profile_delivered_orders_label"
                            android:textColor="@color/mc_text_primary"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_xs"
                            android:text="@string/profile_delivered_orders_description"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_caption" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Tổng tiền đã chi -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_profile_card_spacing"
                    app:cardBackgroundColor="@color/mc_surface"
                    app:cardCornerRadius="@dimen/mc_corner_radius"
                    app:cardElevation="@dimen/mc_card_elevation"
                    app:strokeColor="@color/mc_border"
                    app:strokeWidth="@dimen/mc_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:id="@+id/textViewTotalSpentValue"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:textColor="@color/mc_error"
                            android:textSize="@dimen/mc_profile_metric_value"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:text="@string/profile_total_spent_label"
                            android:textColor="@color/mc_text_primary"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_xs"
                            android:text="@string/profile_total_spent_description"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_caption" />

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- WordCloud -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_lg"
                    app:cardBackgroundColor="@color/mc_surface"
                    app:cardCornerRadius="@dimen/mc_card_radius_large"
                    app:cardElevation="@dimen/mc_card_elevation"
                    app:strokeColor="@color/mc_border"
                    app:strokeWidth="@dimen/mc_stroke_width">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="@dimen/mc_card_padding">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/word_cloud_title"
                            android:textColor="@color/mc_text_primary"
                            android:textSize="@dimen/mc_text_heading"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:text="@string/word_cloud_subtitle"
                            android:textColor="@color/mc_text_secondary"
                            android:textSize="@dimen/mc_text_body" />

                        <TextView
                            android:id="@+id/textViewWordCloudCommentCount"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mc_spacing_sm"
                            android:textColor="@color/mc_primary"
                            android:textSize="@dimen/mc_text_caption"
                            android:textStyle="bold" />

                        <FrameLayout
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/mc_word_cloud_height"
                            android:layout_marginTop="@dimen/mc_spacing_md">

                            <com.example.views.WordCloudView
                                android:id="@+id/wordCloudView"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent" />

                            <TextView
                                android:id="@+id/textViewWordCloudEmpty"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:gravity="center"
                                android:text="@string/word_cloud_empty"
                                android:textColor="@color/mc_text_secondary"
                                android:textSize="@dimen/mc_text_body"
                                android:visibility="gone" />

                        </FrameLayout>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

        </ScrollView>

    </FrameLayout>

</LinearLayout>