<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootReview"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mc_background"
    android:orientation="vertical"
    tools:context=".ReviewActivity">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbarReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/mc_toolbar_height"
        android:background="@color/mc_surface"
        app:navigationIcon="@drawable/ic_arrow_back_24"
        app:title="@string/review_title"
        app:titleTextColor="@color/mc_text_primary" />

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/mc_screen_padding"
            android:paddingTop="@dimen/mc_spacing_lg"
            android:paddingEnd="@dimen/mc_screen_padding"
            android:paddingBottom="@dimen/mc_spacing_xl">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="@dimen/mc_spacing_xs"
                android:text="@string/review_subtitle"
                android:textColor="@color/mc_text_secondary"
                android:textSize="@dimen/mc_text_body" />

            <!-- Thông tin sản phẩm -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_lg"
                app:cardBackgroundColor="@color/mc_surface"
                app:cardCornerRadius="@dimen/mc_corner_radius"
                app:cardElevation="@dimen/mc_card_elevation"
                app:strokeColor="@color/mc_border"
                app:strokeWidth="@dimen/mc_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/mc_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/review_product_heading"
                        android:textColor="@color/mc_text_secondary"
                        android:textSize="@dimen/mc_text_caption"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textViewReviewProductName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mc_spacing_sm"
                        android:textColor="@color/mc_text_primary"
                        android:textSize="@dimen/mc_text_heading"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/textViewReviewCurrentRating"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mc_spacing_sm"
                        android:textColor="@color/mc_warning"
                        android:textSize="@dimen/mc_text_body"
                        android:textStyle="bold" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Chọn số sao -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_md"
                app:cardBackgroundColor="@color/mc_surface"
                app:cardCornerRadius="@dimen/mc_corner_radius"
                app:cardElevation="@dimen/mc_card_elevation"
                app:strokeColor="@color/mc_border"
                app:strokeWidth="@dimen/mc_stroke_width">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_horizontal"
                    android:orientation="vertical"
                    android:padding="@dimen/mc_card_padding">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:text="@string/review_rating_heading"
                        android:textColor="@color/mc_text_primary"
                        android:textSize="@dimen/mc_text_heading"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mc_spacing_sm"
                        android:gravity="center"
                        android:text="@string/review_rating_instruction"
                        android:textColor="@color/mc_text_secondary"
                        android:textSize="@dimen/mc_text_caption" />

                    <RatingBar
                        android:id="@+id/ratingBarReview"
                        style="?android:attr/ratingBarStyle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mc_spacing_md"
                        android:isIndicator="false"
                        android:numStars="5"
                        android:rating="0"
                        android:stepSize="1" />

                    <TextView
                        android:id="@+id/textViewReviewRatingError"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/mc_rating_error_margin"
                        android:gravity="center"
                        android:text="@string/review_rating_required"
                        android:textColor="@color/mc_error"
                        android:textSize="@dimen/mc_text_caption"
                        android:visibility="gone" />

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Bình luận -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_lg"
                android:text="@string/review_comment_heading"
                android:textColor="@color/mc_text_primary"
                android:textSize="@dimen/mc_text_heading"
                android:textStyle="bold" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/textInputLayoutReviewComment"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_sm"
                android:hint="@string/review_comment_hint"
                app:counterEnabled="true"
                app:counterMaxLength="500">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/editTextReviewComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top|start"
                    android:inputType="textCapSentences|textMultiLine"
                    android:maxLength="500"
                    android:minHeight="@dimen/mc_review_comment_min_height"
                    android:minLines="4"
                    android:textColor="@color/mc_text_primary"
                    android:textSize="@dimen/mc_text_body" />

            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_sm"
                android:text="@string/review_security_note"
                android:textColor="@color/mc_text_secondary"
                android:textSize="@dimen/mc_text_caption" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonSubmitReview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_lg"
                android:minHeight="@dimen/mc_button_height"
                android:text="@string/button_submit_review"
                android:textColor="@color/mc_text_on_primary"
                android:textSize="@dimen/mc_text_body"
                android:textStyle="bold"
                app:backgroundTint="@color/mc_primary"
                app:cornerRadius="@dimen/mc_corner_radius" />

        </LinearLayout>

    </ScrollView>

</LinearLayout>