<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/mc_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/mc_screen_padding"
        android:paddingTop="@dimen/mc_spacing_lg"
        android:paddingEnd="@dimen/mc_screen_padding"
        android:paddingBottom="@dimen/mc_spacing_xl">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_name"
            android:textColor="@color/mc_primary"
            android:textSize="@dimen/mc_text_heading"
            android:textStyle="bold" />

        <!-- Thông tin người dùng -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_lg"
            app:cardBackgroundColor="@color/mc_primary"
            app:cardCornerRadius="@dimen/mc_card_radius_large"
            app:cardElevation="@dimen/mc_card_elevation">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/mc_card_padding">

                <TextView
                    android:id="@+id/textViewHomeTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="@color/mc_text_on_primary_muted"
                    android:textSize="@dimen/mc_text_caption"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textViewWelcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_md"
                    android:textColor="@color/mc_text_on_primary"
                    android:textSize="@dimen/mc_text_title"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/textViewRoleDescription"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_sm"
                    android:textColor="@color/mc_text_on_primary_muted"
                    android:textSize="@dimen/mc_text_body"
                    android:textStyle="bold" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Trạng thái phiên -->
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_lg"
            app:cardBackgroundColor="@color/mc_surface"
            app:cardCornerRadius="@dimen/mc_corner_radius"
            app:cardElevation="@dimen/mc_card_elevation"
            app:strokeColor="@color/mc_border"
            app:strokeWidth="@dimen/mc_stroke_width">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/mc_card_padding">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/home_session_title"
                    android:textColor="@color/mc_text_primary"
                    android:textSize="@dimen/mc_text_heading"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mc_spacing_sm"
                    android:lineSpacingExtra="@dimen/mc_spacing_xs"
                    android:text="@string/home_session_description"
                    android:textColor="@color/mc_text_secondary"
                    android:textSize="@dimen/mc_text_body" />

            </LinearLayout>

        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonLogout"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mc_spacing_lg"
            android:minHeight="@dimen/mc_button_height"
            android:text="@string/button_logout"
            android:textColor="@color/mc_error"
            android:textSize="@dimen/mc_text_body"
            app:cornerRadius="@dimen/mc_corner_radius"
            app:strokeColor="@color/mc_error"
            app:strokeWidth="@dimen/mc_stroke_width" />

    </LinearLayout>

</ScrollView>