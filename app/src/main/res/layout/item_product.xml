<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="@dimen/mc_screen_padding"
    android:layout_marginTop="@dimen/mc_spacing_sm"
    android:layout_marginEnd="@dimen/mc_screen_padding"
    android:layout_marginBottom="@dimen/mc_spacing_sm"
    app:cardBackgroundColor="@color/mc_surface"
    app:cardCornerRadius="@dimen/mc_corner_radius"
    app:cardElevation="@dimen/mc_card_elevation"
    app:strokeColor="@color/mc_border"
    app:strokeWidth="@dimen/mc_stroke_width">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="top"
        android:orientation="horizontal"
        android:padding="@dimen/mc_product_item_padding">

        <com.google.android.material.card.MaterialCardView
            android:layout_width="@dimen/mc_product_initial_size"
            android:layout_height="@dimen/mc_product_initial_size"
            app:cardBackgroundColor="@color/mc_primary_soft"
            app:cardCornerRadius="@dimen/mc_corner_radius"
            app:cardElevation="0dp">

            <TextView
                android:id="@+id/textViewProductInitial"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:textColor="@color/mc_primary"
                android:textSize="@dimen/mc_product_initial_text"
                android:textStyle="bold" />

        </com.google.android.material.card.MaterialCardView>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/mc_spacing_md"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/textViewProductCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/mc_primary"
                android:textSize="@dimen/mc_text_small"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewProductName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_xs"
                android:textColor="@color/mc_text_primary"
                android:textSize="@dimen/mc_text_heading"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/textViewProductDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_xs"
                android:ellipsize="end"
                android:maxLines="2"
                android:textColor="@color/mc_text_secondary"
                android:textSize="@dimen/mc_text_caption" />

            <TextView
                android:id="@+id/textViewProductPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_sm"
                android:textColor="@color/mc_error"
                android:textSize="@dimen/mc_text_heading"
                android:textStyle="bold" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_sm"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textViewProductStock"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="@color/mc_text_secondary"
                    android:textSize="@dimen/mc_text_caption" />

                <TextView
                    android:id="@+id/textViewProductRating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/mc_warning"
                    android:textSize="@dimen/mc_text_caption" />

            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/buttonAddToCart"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mc_spacing_md"
                android:minHeight="@dimen/mc_button_height"
                android:text="@string/button_add_to_cart"
                android:textColor="@color/mc_text_on_primary"
                android:textStyle="bold"
                app:backgroundTint="@color/mc_primary"
                app:cornerRadius="@dimen/mc_corner_radius" />

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>